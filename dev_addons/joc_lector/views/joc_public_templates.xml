    <template id="public_review_card" name="Joc Lector Public Review Card">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <h4 class="h5">
                    <a t-att-href="'/lectures/ressenya/%s' % ressenya.slug">
                        <t t-esc="ressenya.llibre_id.name"/>
                    </a>
                </h4>
                <p class="text-muted mb-2" t-esc="ressenya.llibre_id.autor or ''"/>
                <div class="mb-2">
                    <span class="badge bg-success">
                        <t t-esc="ressenya.valoracio"/> / 5
                    </span>
                    <span t-if="ressenya.curs_academic" class="badge bg-secondary">
                        Curs <t t-esc="ressenya.curs_academic"/>
                    </span>
                </div>
                <p t-esc="ressenya.text"/>
                <p class="text-muted small mb-0">
                    Ressenya anonimitzada.
                </p>
            </div>
        </div>
    </template>


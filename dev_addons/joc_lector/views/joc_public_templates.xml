        <div class="card h-100 shadow-sm">
            <t t-if="llibre.portada_1920">
                <img t-att-src="'/web/image/joc.lector.llibre/%s/portada_1920' % llibre.id" class="card-img-top" style="height: 220px; object-fit: cover;" t-att-alt="llibre.name"/>
            </t>
            <div class="card-body">
                <h4 class="h5">
                    <a t-att-href="'/lectures/llibre/%s' % llibre.slug" t-esc="llibre.name"/>
                </h4>
                <p class="text-muted mb-2" t-esc="llibre.autor or ''"/>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary">
                        <t t-esc="llibre.lectura_count"/> lectures
                    </span>
                    <span class="badge bg-success">
                        <t t-esc="'%.1f' % llibre.valoracio_mitjana"/> / 5
                    </span>
                    <span t-if="llibre.categoria" class="badge bg-secondary" t-esc="llibre.categoria"/>
                </div>
            </div>

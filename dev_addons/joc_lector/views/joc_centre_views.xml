<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_joc_lector_centre_tree" model="ir.ui.view">
        <field name="name">joc.lector.centre.tree</field>
        <field name="model">joc.lector.centre</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_joc_lector_centre_form" model="ir.ui.view">
        <field name="name">joc.lector.centre.form</field>
        <field name="model">joc.lector.centre</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Classes">
                            <field name="classe_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="curs_academic"/>
                                    <field name="access_code"/>
                                    <field name="alumne_count"/>
                                    <field name="active"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_joc_lector_centre" model="ir.actions.act_window">
        <field name="name">Centres</field>
        <field name="res_model">joc.lector.centre</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

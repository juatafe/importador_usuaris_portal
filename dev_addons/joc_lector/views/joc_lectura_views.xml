<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_joc_lector_lectura_tree" model="ir.ui.view">
        <field name="name">joc.lector.lectura.tree</field>
        <field name="model">joc.lector.lectura</field>
        <field name="arch" type="xml">
            <tree>
                <field name="alumne_id"/>
                <field name="llibre_id"/>
                <field name="classe_id"/>
                <field name="centre_id"/>
                <field name="curs_academic"/>
                <field name="state"/>
                <field name="estat_validacio"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="punts_generats"/>
                <field name="client_uid"/>
            </tree>
        </field>
    </record>

    <record id="view_joc_lector_lectura_form" model="ir.ui.view">
        <field name="name">joc.lector.lectura.form</field>
        <field name="model">joc.lector.lectura</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="alumne_id"/>
                            <field name="llibre_id"/>
                            <field name="classe_id"/>
                            <field name="centre_id" readonly="1"/>
                            <field name="curs_academic" readonly="1"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="estat_validacio"/>
                            <field name="professor_validador_id"/>
                            <field name="data_validacio"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="punts_generats"/>
                            <field name="points_applied" readonly="1"/>
                            <field name="client_uid"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Aportació alumne">
                            <field name="valoracio"/>
                            <field name="ressenya"/>
                            <field name="evidencia_url"/>
                            <field name="evidencia_text"/>
                            <field name="visible_publicament"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                        <page string="Ressenyes">
                            <field name="ressenya_ids">
                                <tree>
                                    <field name="valoracio"/>
                                    <field name="publicable"/>
                                    <field name="aprovada"/>
                                    <field name="classe_id"/>
                                    <field name="curs_academic"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_joc_lector_lectura" model="ir.actions.act_window">
        <field name="name">Lectures</field>
        <field name="res_model">joc.lector.lectura</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
